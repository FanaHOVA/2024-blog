---
import { Image } from 'astro:assets'
import Base from '../layouts/Base.astro'
import kobeMj from '../assets/inspiration/kobe-mj.jpeg'
import asr3 from '../assets/inspiration/asr3.jpeg'
import kobeLeft from '../assets/inspiration/kobe-left.jpeg'
import spaceTesla from '../assets/inspiration/space-tesla.avif'
import jobsGates from '../assets/inspiration/jobs-gates.webp'
import swatt from '../assets/inspiration/swatt.jpeg'
import dante from '../assets/inspiration/dante.jpeg'
import lotr1 from '../assets/inspiration/lotr1.jpeg'
import rd from '../assets/inspiration/rd.jpg'
import fermi from '../assets/inspiration/fermi.webp'

const items = [
  { id: 'kobe-mj', src: kobeMj, alt: 'Kobe Bryant and Michael Jordan', shape: 'cinema', tone: '#e24c2f', x: 2, y: 2, w: 25, rot: -2.5 },
  { id: 'dante', src: dante, alt: 'Dante Alighieri portrait', shape: 'portrait', tone: '#7f55b1', x: 53, y: 2, w: 16, rot: 4 },
  { id: 'asr', src: asr3, alt: 'ASR scene', shape: 'wide', tone: '#2e8f72', x: 4, y: 32, w: 26, rot: 2 },
  { id: 'jobs-gates', src: jobsGates, alt: 'Steve Jobs and Bill Gates', shape: 'wide', tone: '#0f7ac0', x: 29, y: 5, w: 22, rot: 2.5 },
  { id: 'fermi', src: fermi, alt: 'Enrico Fermi', shape: 'wide', tone: '#c17a19', x: 72, y: 6, w: 22, rot: -3.2 },
  { id: 'kobe-left', src: kobeLeft, alt: 'Kobe Bryant', shape: 'portrait', tone: '#7048a8', x: 33, y: 29, w: 18, rot: -3.5 },
  { id: 'space-tesla', src: spaceTesla, alt: 'Tesla Roadster in orbit', shape: 'cinema', tone: '#d34876', x: 54, y: 34, w: 32, rot: 2.4 },
  { id: 'swatt', src: swatt, alt: 'Swatt scene', shape: 'wide', tone: '#2f7d89', x: 6, y: 66, w: 27, rot: 1.8 },
  { id: 'lotr', src: lotr1, alt: 'The Fellowship from The Lord of the Rings', shape: 'portrait', tone: '#6b8d2f', x: 64, y: 66, w: 18, rot: -4 },
  { id: 'rd', src: rd, alt: 'RD portrait', shape: 'square', tone: '#b94f39', x: 36, y: 62, w: 22, rot: 3 }
]

const galleryWidths = [320, 480, 640, 900, 1200]
const gallerySizes = '(max-width: 760px) calc(100vw - 2.5rem), 32vw'
---

<Base title="Inspiration" description="A living collection of things that have gotten under my skin.">
  <div class="inspiration-shell">
    <section class="scatter" aria-label="Scattered inspiration collection">
      {items.map((item, index) => (
        <article
          class={`scatter-card scatter-${item.shape}`}
          style={`--tone: ${item.tone}; --x: ${item.x}%; --y: ${item.y}%; --w: ${item.w}%; --rot: ${item.rot}deg; --z: ${index + 1}; --delay: ${index * 54}ms;`}
        >
          <a class="scatter-image" href={item.src.src} aria-label={item.alt}>
            <Image
              src={item.src}
              alt={item.alt}
              widths={galleryWidths}
              sizes={gallerySizes}
              loading={index < 2 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </a>
        </article>
      ))}
    </section>
  </div>

  <div class="focus-stage" id="focus-stage" aria-hidden="true">
    <button class="focus-close" type="button" aria-label="Close">&times;</button>
    <img class="focus-image" alt="" />
  </div>
</Base>

<script is:inline>
  (() => {
    if (window.__inspirationFocus) return
    window.__inspirationFocus = true

    let source = null
    let returnTarget = null

    const rotationOf = (el) => {
      const card = el.closest('.scatter-card')
      if (!card) return 0
      return parseFloat(getComputedStyle(card).getPropertyValue('--rot')) || 0
    }

    const sourceFrame = (el) => {
      const r = el.getBoundingClientRect()
      const w = el.offsetWidth
      const h = el.offsetHeight
      const cx = r.left + r.width / 2
      const cy = r.top + r.height / 2
      return {
        w,
        h,
        transform: `translate(${cx - w / 2}px, ${cy - h / 2}px) rotate(${rotationOf(el)}deg)`
      }
    }

    const open = (link) => {
      const stage = document.getElementById('focus-stage')
      if (!stage || source) return
      const fimg = stage.querySelector('.focus-image')
      const inner = link.querySelector('img')
      if (!inner || !fimg) return

      source = inner
      returnTarget = link

      if (inner.srcset) fimg.srcset = inner.srcset
      fimg.sizes = '100vw'
      fimg.src = inner.currentSrc || inner.src
      fimg.alt = inner.alt || ''
      const ratio = inner.naturalWidth / inner.naturalHeight
      if (ratio > 0) fimg.style.setProperty('--ar', ratio)

      const from = sourceFrame(inner)
      inner.style.visibility = 'hidden'

      fimg.style.transition = 'none'
      fimg.style.width = from.w + 'px'
      fimg.style.height = from.h + 'px'
      fimg.style.transform = from.transform
      void fimg.offsetWidth

      stage.dataset.active = ''
      stage.setAttribute('aria-hidden', 'false')

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          fimg.style.transition = ''
          fimg.style.width = ''
          fimg.style.height = ''
          fimg.style.transform = ''
        })
      })
    }

    const close = () => {
      const stage = document.getElementById('focus-stage')
      if (!stage || !source) return
      const fimg = stage.querySelector('.focus-image')
      const src = source
      const ret = returnTarget

      const cleanup = () => {
        fimg.style.transition = 'none'
        fimg.style.transform = ''
        fimg.style.width = ''
        fimg.style.height = ''
        void fimg.offsetWidth
        fimg.style.transition = ''
        if (src) src.style.visibility = ''
        source = null
        returnTarget = null
        if (ret && typeof ret.focus === 'function') ret.focus({ preventScroll: true })
      }

      if (!document.body.contains(src)) {
        stage.removeAttribute('data-active')
        stage.setAttribute('aria-hidden', 'true')
        cleanup()
        return
      }

      const to = sourceFrame(src)
      const handler = (e) => {
        if (e.propertyName !== 'transform' || e.target !== fimg) return
        fimg.removeEventListener('transitionend', handler)
        cleanup()
      }
      fimg.addEventListener('transitionend', handler)

      stage.removeAttribute('data-active')
      stage.setAttribute('aria-hidden', 'true')
      fimg.style.width = to.w + 'px'
      fimg.style.height = to.h + 'px'
      fimg.style.transform = to.transform
    }

    document.addEventListener('click', (e) => {
      const link = e.target.closest('.scatter-image')
      if (link && !source) {
        e.preventDefault()
        open(link)
        return
      }
      if (!source) return
      const stage = document.getElementById('focus-stage')
      if (!stage) return
      if (e.target === stage || e.target.classList.contains('focus-close')) {
        close()
      }
    })

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && source) {
        e.preventDefault()
        close()
      }
    })
  })()
</script>

<style>
  .inspiration-shell {
    position: relative;
    left: 50%;
    width: 100vw;
    margin-top: clamp(2rem, 6vw, 5rem);
    margin-bottom: 6rem;
    transform: translateX(-50%);
  }

  .inspiration-shell::before {
    content: '';
    position: absolute;
    inset: 3rem 0 auto 0;
    height: 78vh;
    min-height: 520px;
    z-index: -1;
    background:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: radial-gradient(ellipse at 70% 45%, black, transparent 70%);
    opacity: 0.28;
    pointer-events: none;
  }

  .scatter-image :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    margin: 0;
    border-radius: 0;
    object-fit: cover;
  }

  .scatter {
    position: relative;
    width: 100%;
    aspect-ratio: 1280 / 900;
    isolation: isolate;
  }

  .scatter::before {
    content: '';
    position: absolute;
    inset: 4% 6% 6%;
    z-index: -2;
    background:
      radial-gradient(circle at 18% 18%, color-mix(in srgb, #e24c2f, transparent 78%), transparent 22vw),
      radial-gradient(circle at 76% 42%, color-mix(in srgb, #2e8f72, transparent 82%), transparent 24vw),
      radial-gradient(circle at 42% 73%, color-mix(in srgb, #d34876, transparent 83%), transparent 26vw);
    filter: blur(14px);
    opacity: 0.58;
    pointer-events: none;
  }

  .scatter::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(115deg, transparent 0 46%, color-mix(in srgb, var(--border), transparent 28%) 46% 46.12%, transparent 46.12%),
      linear-gradient(70deg, transparent 0 59%, color-mix(in srgb, var(--border), transparent 42%) 59% 59.08%, transparent 59.08%);
    opacity: 0.34;
    pointer-events: none;
  }

  @property --angle {
    syntax: '<angle>';
    inherits: false;
    initial-value: 0deg;
  }

  @property --lift {
    syntax: '<length>';
    inherits: false;
    initial-value: 0px;
  }

  @property --scale {
    syntax: '<number>';
    inherits: false;
    initial-value: 1;
  }

  .scatter-card {
    --angle: var(--rot);
    --lift: 0rem;
    --scale: 1;
    position: absolute;
    top: var(--y);
    left: var(--x);
    width: var(--w);
    z-index: var(--z);
    opacity: 1;
    filter: saturate(1) brightness(1);
    transform: rotate(var(--angle)) translate3d(0, var(--lift), 0) scale(var(--scale));
    transform-origin: 50% 50%;
    scroll-margin-top: 4rem;
    animation: scatter-arrive 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--delay);
    transition:
      --angle 720ms cubic-bezier(0.5, 0, 0.2, 1),
      --lift 520ms cubic-bezier(0.16, 1, 0.3, 1),
      --scale 520ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 340ms ease,
      filter 340ms ease;
    will-change: transform, opacity, filter;
  }

  .scatter-card::after {
    content: '';
    position: absolute;
    inset: 0.55rem -0.55rem -0.55rem 0.55rem;
    z-index: -1;
    border-radius: 8px;
    background: color-mix(in srgb, var(--tone), transparent 87%);
    opacity: 0.55;
    transition: opacity 340ms ease, transform 460ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scatter-image {
    position: relative;
    display: block;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--tone), var(--border) 56%);
    border-radius: 8px;
    background: var(--code-bg);
    box-shadow:
      0 28px 70px -50px color-mix(in srgb, var(--tone), #000 58%),
      0 2px 10px -8px rgba(0, 0, 0, 0.8);
    text-decoration: none;
    cursor: zoom-in;
    transform: translateZ(0);
    transition:
      box-shadow 420ms cubic-bezier(0.16, 1, 0.3, 1),
      filter 340ms ease,
      transform 460ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scatter-image::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--tone), transparent 84%), transparent 50%),
      linear-gradient(0deg, rgba(0, 0, 0, 0.16), transparent 38%);
    opacity: 0.35;
    transition: opacity 340ms ease;
    pointer-events: none;
  }

  .scatter-cinema .scatter-image {
    aspect-ratio: 1.9;
  }

  .scatter-wide .scatter-image {
    aspect-ratio: 1.42;
  }

  .scatter-portrait .scatter-image {
    aspect-ratio: 0.86;
  }

  .scatter-square .scatter-image {
    aspect-ratio: 1;
  }

  @media (hover: hover) {
    .scatter:has(.scatter-card:hover) .scatter-card:not(:hover) {
      opacity: 0.62;
      filter: saturate(0.78) brightness(0.86);
    }

    .scatter-card:hover {
      --angle: 0deg;
      --lift: -1rem;
      --scale: 1.055;
      z-index: 40;
    }

    .scatter-card:hover::after {
      opacity: 0.78;
      transform: translate3d(0, 0.35rem, 0) scale(1.01);
    }

    .scatter-card:hover .scatter-image {
      filter: saturate(1.05);
      transform: translateZ(0) scale(1.012);
      box-shadow:
        0 54px 130px -60px color-mix(in srgb, var(--tone), #000 38%),
        0 18px 36px -26px rgba(0, 0, 0, 0.9);
    }

    .scatter-card:hover .scatter-image::before {
      opacity: 0.2;
    }
  }

  @keyframes scatter-arrive {
    from {
      opacity: 0;
      filter: saturate(0.8) blur(2px);
      transform: rotate(calc(var(--angle) - 3deg)) translate3d(0, 1.4rem, 0) scale(0.96);
    }

    to {
      opacity: 1;
      filter: saturate(1) blur(0);
      transform: rotate(var(--angle)) translate3d(0, var(--lift), 0) scale(var(--scale));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scatter-card {
      animation: none;
      transition: none;
    }

    .scatter-image,
    .scatter-image::before,
    .scatter-card::after {
      transition: none;
    }
  }

  .scatter-image:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 5px;
  }

  .focus-stage {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0);
    pointer-events: none;
    visibility: hidden;
    transition:
      background 460ms cubic-bezier(0.16, 1, 0.3, 1),
      backdrop-filter 460ms cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0s 460ms;
  }

  .focus-stage[data-active] {
    background: rgba(0, 0, 0, 0.86);
    backdrop-filter: blur(10px);
    pointer-events: auto;
    visibility: visible;
    transition-delay: 0s;
  }

  .focus-image {
    --w-target: min(92vw, calc(92vh * var(--ar, 1)));
    --h-target: calc(var(--w-target) / var(--ar, 1));
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    width: var(--w-target);
    height: var(--h-target);
    margin: 0;
    border-radius: 4px;
    box-shadow: 0 40px 120px -40px rgba(0, 0, 0, 0.9);
    object-fit: cover;
    transform-origin: 50% 50%;
    transform: translate(calc((100vw - var(--w-target)) / 2), calc((100vh - var(--h-target)) / 2)) rotate(0deg);
    transition:
      width 460ms cubic-bezier(0.16, 1, 0.3, 1),
      height 460ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 460ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, width, height;
  }

  .focus-close {
    position: fixed;
    top: 1.25rem;
    right: 1.5rem;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.92);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0;
    transition: background 200ms ease, transform 200ms ease, opacity 220ms ease;
  }

  .focus-stage[data-active] .focus-close {
    opacity: 1;
  }

  .focus-close:hover {
    background: rgba(255, 255, 255, 0.22);
    transform: scale(1.06);
  }

  @media (max-width: 980px) {
    .inspiration-shell {
      margin-top: 1.5rem;
    }

    .scatter {
      aspect-ratio: auto;
      min-height: 0;
      display: grid;
      grid-template-columns: repeat(8, minmax(0, 1fr));
      gap: 0 1rem;
      padding: 0 1rem;
      margin-top: -1.5rem;
    }

    .scatter::before {
      inset: 0 0 12rem;
    }

    .scatter-card {
      position: relative;
      top: auto;
      left: auto;
      width: auto;
      --angle: var(--rot);
    }

    .scatter-card:nth-child(odd) {
      grid-column: 1 / 6;
    }

    .scatter-card:nth-child(even) {
      grid-column: 4 / -1;
      margin-top: -4.8rem;
    }

    .scatter-card:nth-child(3n) {
      grid-column: 2 / 8;
      margin-top: -3.4rem;
    }
  }

  @media (max-width: 760px) {
    .inspiration-shell {
      margin-top: 2rem;
    }

    .inspiration-shell::before {
      inset: 2rem 0 auto 0;
      min-height: 430px;
    }

    .scatter {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 1.5rem 1.25rem 0;
    }

    .scatter::after {
      inset: 0;
    }

    .scatter-card,
    .scatter-card:nth-child(odd),
    .scatter-card:nth-child(even),
    .scatter-card:nth-child(3n) {
      grid-column: 1;
      width: 88%;
      margin-top: -3.4rem;
    }

    .scatter-card:nth-child(odd) {
      justify-self: start;
      --angle: -1.8deg;
    }

    .scatter-card:nth-child(even) {
      justify-self: end;
      --angle: 1.4deg;
    }

    .scatter-card:first-child {
      margin-top: 0;
    }

    .scatter-card:nth-child(3n) {
      justify-self: center;
      width: 94%;
    }

    .scatter-card::after {
      display: none;
    }

    .scatter-cinema .scatter-image,
    .scatter-wide .scatter-image,
    .scatter-square .scatter-image {
      aspect-ratio: 1.16;
    }

    .scatter-portrait .scatter-image {
      aspect-ratio: 0.92;
    }
  }
</style>
