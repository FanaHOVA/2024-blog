---
import { Image } from 'astro:assets'
import Base from '../layouts/Base.astro'
import kobeMj from '../assets/inspiration/kobe-mj.jpeg'
import asr3 from '../assets/inspiration/asr3.jpeg'
import kobeLeft from '../assets/inspiration/kobe-left.jpeg'
import spaceTesla from '../assets/inspiration/space-tesla.avif'
import jobsGates from '../assets/inspiration/jobs-gates.webp'
import swatt from '../assets/inspiration/swatt.jpeg'
import dante from '../assets/inspiration/dante.jpeg'
import lotr1 from '../assets/inspiration/lotr1.jpeg'
import rd from '../assets/inspiration/rd.jpg'
import fermi from '../assets/inspiration/fermi.webp'

// layout: 'hero' | 'right' | 'left'
// Items flow as a slow editorial cadence: big hero, then alternating inset
// pieces, returning to hero as breathing room.
const items = [
  { src: kobeMj,     alt: 'Kobe Bryant and Michael Jordan', layout: 'hero'  },
  { src: dante,      alt: 'Dante',                          layout: 'right' },
  { src: asr3,       alt: 'ASR',                            layout: 'left'  },
  { src: jobsGates,  alt: 'Jobs & Gates',                   layout: 'hero'  },
  { src: fermi,      alt: 'Fermi',                          layout: 'right' },
  { src: kobeLeft,   alt: 'Kobe Bryant',                    layout: 'left'  },
  { src: spaceTesla, alt: 'Roadster in orbit',              layout: 'hero'  },
  { src: swatt,      alt: 'Swatt',                          layout: 'right' },
  { src: lotr1,      alt: 'The Fellowship',                 layout: 'left'  },
  { src: rd,         alt: 'RD',                             layout: 'hero'  }
]

const heroSizes  = '(max-width: 900px) 100vw, 1100px'
const insetSizes = '(max-width: 900px) 100vw, 620px'
---

<Base title="Inspiration" description="A living collection of things that have gotten under my skin.">
  <section class="hero">
    <p class="kicker">Collection · ongoing</p>
    <h1 class="title">Inspiration<span class="dot">.</span></h1>
    <p class="dek">A slow-growing gallery of things that have gotten under my skin — books, movies, images, moments. Usually less about the artifact, more about the story behind it.</p>
    <p class="hint">Click any image to see it full-size · ← → to navigate · Esc to close</p>
  </section>

  <article class="feed">
    {items.map((item, i) => (
      <section class={`piece piece-${item.layout}`}>
        <figure>
          <button class="trigger" data-index={i} aria-label={`Open ${item.alt} full-size`} type="button">
            <Image
              src={item.src}
              alt={item.alt}
              widths={item.layout === 'hero' ? [600, 900, 1200, 1600] : [400, 600, 900]}
              sizes={item.layout === 'hero' ? heroSizes : insetSizes}
              loading={i < 2 ? 'eager' : 'lazy'}
            />
          </button>
        </figure>
        <aside class="meta">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <h2>{item.alt}</h2>
        </aside>
      </section>
    ))}
  </article>

  <dialog class="lightbox" id="lightbox" aria-label="Image viewer">
    <div class="lb-stage">
      <img class="lb-img" alt="" />
    </div>
    <div class="lb-chrome">
      <span class="lb-caption"></span>
      <span class="lb-counter"><span class="lb-idx">01</span><span class="lb-slash">/</span><span class="lb-total">10</span></span>
    </div>
    <button class="lb-close" aria-label="Close" type="button">Close</button>
    <button class="lb-prev" aria-label="Previous image" type="button">←</button>
    <button class="lb-next" aria-label="Next image" type="button">→</button>
  </dialog>
</Base>

<script is:inline data-astro-rerun>
  (() => {
    const dialog = document.getElementById('lightbox')
    if (!dialog || dialog.dataset.bound) return
    dialog.dataset.bound = '1'

    const triggers = [...document.querySelectorAll('.trigger')]
    const lbImg = dialog.querySelector('.lb-img')
    const lbCap = dialog.querySelector('.lb-caption')
    const lbIdx = dialog.querySelector('.lb-idx')
    const lbTot = dialog.querySelector('.lb-total')

    const images = triggers.map((t) => {
      const img = t.querySelector('img')
      return {
        src: img.currentSrc || img.src,
        srcset: img.srcset || '',
        sizes: img.sizes || '100vw',
        alt: img.alt
      }
    })
    lbTot.textContent = String(images.length).padStart(2, '0')
    let current = 0

    const apply = () => {
      const it = images[current]
      lbImg.srcset = it.srcset
      lbImg.sizes = '100vw'
      lbImg.src = it.src
      lbImg.alt = it.alt
      lbCap.textContent = it.alt
      lbIdx.textContent = String(current + 1).padStart(2, '0')
    }

    const withTransition = (fn) => {
      if (document.startViewTransition) document.startViewTransition(fn)
      else fn()
    }

    const show = (i) => {
      current = ((i % images.length) + images.length) % images.length
      withTransition(apply)
    }

    const openAt = (i) => {
      current = ((i % images.length) + images.length) % images.length
      apply()
      dialog.showModal()
    }

    triggers.forEach((t, i) => t.addEventListener('click', () => openAt(i)))
    dialog.querySelector('.lb-close').addEventListener('click', () => dialog.close())
    dialog.querySelector('.lb-prev').addEventListener('click', () => show(current - 1))
    dialog.querySelector('.lb-next').addEventListener('click', () => show(current + 1))
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close()
    })
    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return
      if (e.key === 'ArrowLeft')  { e.preventDefault(); show(current - 1) }
      if (e.key === 'ArrowRight') { e.preventDefault(); show(current + 1) }
    })
  })()
</script>

<style>
  /* ------------ Hero ------------ */
  .hero {
    padding: 4rem 0 3rem;
    max-width: 640px;
  }
  .kicker {
    text-transform: uppercase;
    font-size: 0.72rem;
    font-variation-settings: 'wght' 600;
    letter-spacing: 0.18em;
    color: var(--muted);
    margin: 0 0 1.5rem;
  }
  .title {
    font-family: 'Iowan Old Style', 'Charter', 'Apple Garamond', Georgia, serif;
    font-feature-settings: 'liga', 'calt';
    font-size: clamp(3.5rem, 11vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    margin: 0 0 1.5rem;
    font-weight: 400;
    font-style: italic;
  }
  .title .dot {
    color: var(--accent);
    font-style: normal;
  }
  .dek {
    font-size: 1.15rem;
    line-height: 1.55;
    color: var(--text);
    max-width: 520px;
    margin: 0 0 1.75rem;
  }
  .hint {
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: var(--muted);
    margin: 0;
  }

  /* ------------ Feed ------------ */
  .feed {
    display: flex;
    flex-direction: column;
    gap: 6.5rem;
    margin: 4rem 0 6rem;
    width: min(1240px, calc(100vw - 2.5rem));
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }

  .piece {
    display: grid;
    gap: 1.5rem 2.5rem;
    align-items: end;
  }
  .piece figure { margin: 0; }
  .piece .meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }
  .num {
    font-family: 'Iowan Old Style', 'Charter', Georgia, serif;
    font-style: italic;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--accent);
    line-height: 1;
    font-variant-numeric: lining-nums tabular-nums;
  }
  .piece h2 {
    font-family: 'Iowan Old Style', 'Charter', Georgia, serif;
    font-weight: 400;
    font-size: clamp(1.4rem, 2.2vw, 1.9rem);
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin: 0;
  }

  /* Layout variants */
  .piece-hero {
    grid-template-columns: 1fr;
  }
  .piece-hero figure { order: 1; }
  .piece-hero .meta  { order: 2; padding-top: 0.5rem; }

  .piece-right {
    grid-template-columns: minmax(0, 1fr) minmax(220px, 280px);
  }
  .piece-right figure { order: 1; }
  .piece-right .meta  { order: 2; flex-direction: column; align-items: flex-start; gap: 0.6rem; padding-bottom: 0.5rem; }

  .piece-left {
    grid-template-columns: minmax(220px, 280px) minmax(0, 1fr);
  }
  .piece-left figure { order: 2; }
  .piece-left .meta  { order: 1; flex-direction: column; align-items: flex-start; gap: 0.6rem; padding-bottom: 0.5rem; }

  /* ------------ Image ------------ */
  .trigger {
    all: unset;
    display: block;
    cursor: zoom-in;
    width: 100%;
    border-radius: 6px;
    overflow: hidden;
    background: var(--code-bg);
    transition: transform 0.5s cubic-bezier(.2, .8, .2, 1),
                box-shadow 0.5s cubic-bezier(.2, .8, .2, 1);
    -webkit-tap-highlight-color: transparent;
  }
  .trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }
  .trigger :global(img) {
    display: block;
    width: 100%;
    height: auto;
    margin: 0;
    border-radius: 0;
    transition: transform 0.7s cubic-bezier(.2, .8, .2, 1),
                filter 0.4s ease;
  }

  @media (hover: hover) {
    .trigger:hover {
      transform: translateY(-3px);
      box-shadow:
        0 30px 60px -24px rgba(0, 0, 0, 0.35),
        0 0 0 1px rgba(255, 255, 255, 0.04);
    }
    .trigger:hover :global(img) {
      transform: scale(1.015);
      filter: saturate(1.04);
    }
  }

  /* ------------ Scroll reveal ------------ */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .piece {
        animation: reveal linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 18%;
      }
      @keyframes reveal {
        from { opacity: 0; transform: translateY(40px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    }
  }

  /* ------------ Lightbox ------------ */
  dialog.lightbox {
    padding: 0;
    margin: 0;
    width: 100vw;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100dvh;
    border: 0;
    background: rgba(8, 10, 14, 0.94);
    color: white;
    overflow: hidden;
  }
  dialog.lightbox::backdrop {
    background: transparent;
  }

  .lb-stage {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 4rem 5rem;
  }
  .lb-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
    view-transition-name: lb-img;
  }
  .lb-chrome {
    position: absolute;
    left: 0; right: 0; bottom: 1.5rem;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 1.25rem;
    padding: 0 2rem;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.8);
    pointer-events: none;
  }
  .lb-caption {
    font-variation-settings: 'wght' 500;
    letter-spacing: -0.01em;
  }
  .lb-counter {
    font-family: 'Iowan Old Style', 'Charter', Georgia, serif;
    font-style: italic;
    color: rgba(255,255,255,0.5);
    font-variant-numeric: tabular-nums;
  }
  .lb-slash { margin: 0 0.25rem; }

  .lightbox button {
    position: absolute;
    background: rgba(255,255,255,0.06);
    color: white;
    border: 1px solid rgba(255,255,255,0.12);
    cursor: pointer;
    font: inherit;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: background 0.2s, transform 0.2s, border-color 0.2s;
  }
  .lightbox button:hover {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.24);
  }
  .lightbox button:active { transform: scale(0.96); }
  .lightbox button:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }
  .lb-close {
    top: 1.25rem; right: 1.25rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .lb-prev, .lb-next {
    top: 50%; transform: translateY(-50%);
    width: 48px; height: 48px;
    border-radius: 50%;
    font-size: 1.2rem;
    display: grid; place-items: center;
  }
  .lb-prev { left: 1.25rem; }
  .lb-next { right: 1.25rem; }
  .lb-prev:active, .lb-next:active { transform: translateY(-50%) scale(0.96); }

  @media (prefers-reduced-motion: no-preference) {
    ::view-transition-old(lb-img),
    ::view-transition-new(lb-img) {
      animation-duration: 0.4s;
      animation-timing-function: cubic-bezier(.2, .8, .2, 1);
    }
  }

  /* ------------ Responsive ------------ */
  @media (max-width: 900px) {
    .feed { gap: 4.5rem; }
    .piece-right, .piece-left {
      grid-template-columns: 1fr;
    }
    .piece-right figure, .piece-left figure { order: 1; }
    .piece-right .meta,  .piece-left .meta  { order: 2; flex-direction: row; align-items: baseline; padding-top: 0.25rem; }
    .lb-stage { padding: 3rem 1rem 4rem; }
    .lb-prev { left: 0.5rem; }
    .lb-next { right: 0.5rem; }
  }

  @media (max-width: 520px) {
    .hero { padding: 2.5rem 0 2rem; }
    .feed { gap: 3.5rem; margin: 2rem 0 4rem; }
    .lb-chrome { font-size: 0.78rem; gap: 0.75rem; }
  }
</style>
