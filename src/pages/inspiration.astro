---
import { Image } from 'astro:assets'
import Base from '../layouts/Base.astro'
import kobeMj from '../assets/inspiration/kobe-mj.jpeg'
import asr3 from '../assets/inspiration/asr3.jpeg'
import kobeLeft from '../assets/inspiration/kobe-left.jpeg'
import spaceTesla from '../assets/inspiration/space-tesla.avif'
import jobsGates from '../assets/inspiration/jobs-gates.webp'
import swatt from '../assets/inspiration/swatt.jpeg'
import dante from '../assets/inspiration/dante.jpeg'
import lotr1 from '../assets/inspiration/lotr1.jpeg'
import rd from '../assets/inspiration/rd.jpg'
import fermi from '../assets/inspiration/fermi.webp'

// Ordered so columns end up roughly balanced with a good tall/wide mix.
const items = [
  { src: kobeMj,     alt: 'Kobe Bryant and Michael Jordan' },
  { src: spaceTesla, alt: 'Roadster in orbit' },
  { src: dante,      alt: 'Dante' },
  { src: asr3,       alt: 'ASR' },
  { src: jobsGates,  alt: 'Jobs & Gates' },
  { src: lotr1,      alt: 'The Fellowship' },
  { src: kobeLeft,   alt: 'Kobe Bryant' },
  { src: swatt,      alt: 'Swatt' },
  { src: rd,         alt: 'RD' },
  { src: fermi,      alt: 'Fermi' }
]

const sizes = '(max-width: 520px) 100vw, (max-width: 900px) 48vw, 380px'
---

<Base title="Inspiration" description="A collection of things that inspire me.">
  <section class="inspiration-intro">
    <h1>Inspiration</h1>
    <p>A collection of things that have gotten under my skin — books, movies, images, moments. Usually less about the artifact, more about the story behind it.</p>
  </section>

  <div class="gallery">
    {items.map((item) => (
      <figure>
        <Image src={item.src} alt={item.alt} widths={[400, 600, 800]} sizes={sizes} loading="lazy" />
        <figcaption>{item.alt}</figcaption>
      </figure>
    ))}
  </div>
</Base>

<style>
  .inspiration-intro {
    padding: 3rem 0 2.5rem;
    max-width: 560px;
  }
  .inspiration-intro h1 {
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-variation-settings: 'wght' 850;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0 0 1rem;
    background: linear-gradient(135deg, var(--text) 0%, var(--accent) 140%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .inspiration-intro p {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.55;
    margin: 0;
  }

  .gallery {
    columns: 3;
    column-gap: 14px;
    width: min(1200px, calc(100vw - 2.5rem));
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin: 2rem 0 5rem;
  }

  .gallery figure {
    break-inside: avoid;
    margin: 0 0 14px;
    padding: 0;
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    background: var(--code-bg);
    transition: transform 0.4s cubic-bezier(.2, .8, .2, 1),
                box-shadow 0.4s cubic-bezier(.2, .8, .2, 1);
  }

  .gallery :global(img) {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    border-radius: 0;
    transition: transform 0.6s cubic-bezier(.2, .8, .2, 1);
    will-change: transform;
  }

  .gallery figcaption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 2.2rem 1rem 0.9rem;
    color: white;
    font-size: 0.85rem;
    font-variation-settings: 'wght' 550;
    letter-spacing: -0.01em;
    background: linear-gradient(to top,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.45) 55%,
      rgba(0, 0, 0, 0) 100%);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }

  @media (hover: hover) {
    .gallery figure:hover {
      transform: translateY(-4px);
      box-shadow:
        0 22px 44px -18px rgba(0, 0, 0, 0.35),
        0 0 0 1px rgba(255, 255, 255, 0.05);
      z-index: 2;
    }
    .gallery figure:hover :global(img) {
      transform: scale(1.03);
    }
    .gallery figure:hover figcaption {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (hover: none) {
    .gallery figcaption {
      opacity: 1;
      transform: translateY(0);
      background: linear-gradient(to top, rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0) 80%);
    }
  }

  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .gallery figure {
        animation: fade-up linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 15%;
      }
      @keyframes fade-up {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    }
  }

  @media (max-width: 900px) {
    .gallery {
      columns: 2;
      column-gap: 10px;
    }
  }

  @media (max-width: 520px) {
    .gallery {
      columns: 1;
    }
  }
</style>
