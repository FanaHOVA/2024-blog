---
---
<button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" type="button">
  <span data-when="light">Dark</span>
  <span data-when="dark">Light</span>
</button>

<style>
  .theme-toggle [data-when] { display: none; }
  :root[data-theme='light'] .theme-toggle [data-when='light'],
  :root:not([data-theme='dark']) .theme-toggle [data-when='light'] { display: inline; }
  :root[data-theme='dark'] .theme-toggle [data-when='dark'] { display: inline; }
</style>

<script is:inline data-astro-rerun>
  (() => {
    const btn = document.getElementById('theme-toggle')
    if (!btn || btn.dataset.bound) return
    btn.dataset.bound = '1'
    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light'
      const next = current === 'dark' ? 'light' : 'dark'
      document.documentElement.setAttribute('data-theme', next)
      try { localStorage.setItem('theme', next) } catch {}
    })
  })()
</script>
